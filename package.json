{
  "name": "syncmeet",
  "version": "1.0.0",
  "type": "module",
  "description": "A minimal, low-latency 1:1 video calling platform with screen sharing and chat.",
  "main": "index.tsx",
  "scripts": {
    "start": "vite",
    "server": "npm --prefix server start",
    "dev": "concurrently \"npm run start\" \"npm run server\"",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "keywords": [
    "webrtc",
    "video-call",
    "react",
    "typescript"
  ],
  "author": "SyncMeet Team",
  "license": "MIT",
  "dependencies": {
    "@types/node": "^25.5.0",
    "buffer": "^6.0.3",
    "concurrently": "^9.2.1",
    "events": "^3.3.0",
    "lucide-react": "^0.400.0",
    "peerjs": "^1.5.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "simple-peer": "^9.11.1",
    "socket.io-client": "^4.8.3",
    "trystero": "^0.19.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/simple-peer": "^9.11.9",
    "@vitejs/plugin-react": "^3.1.0",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.0.0",
    "vite": "^4.4.0"
  }
}
